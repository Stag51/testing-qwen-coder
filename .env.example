# Federated Learning Configuration
FED_NUM_CLIENTS=5
FED_AGGREGATION_ROUNDS=100
FED_LOCAL_EPOCHS=5
FED_BATCH_SIZE=32
FED_LEARNING_RATE=0.001
FED_DIFFERENTIAL_PRIVACY_EPSILON=1.0
FED_DIFFERENTIAL_PRIVACY_DELTA=1e-5

# Qdrant Vector Database Configuration
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_RADIOLOGY_COLLECTION=radiology_embeddings
QDRANT_GENOMICS_COLLECTION=genomics_embeddings
QDRANT_FUSION_COLLECTION=fusion_embeddings
QDRANT_EMBEDDING_DIM=768

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false
API_CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# NVIDIA BioNeMo Configuration (Optional)
BIONEMO_API_KEY=your_api_key_here
BIONEMO_BASE_URL=https://api.bionemo.nvidia.com/v1
BIONEMO_MODEL_NAME=nvidia/bionemo-large

# FHIR Server Configuration
FHIR_SERVER_URL=http://localhost:8080/fhir
FHIR_USERNAME=
FHIR_PASSWORD=

# General Configuration
LOG_LEVEL=INFO
DATA_DIR=./data
MODEL_DIR=./models
CACHE_DIR=./cache
